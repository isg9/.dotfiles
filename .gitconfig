[user]
	name = Isai Gordeev
	email = isaigordeev@gmail.com
	signingkey = E32BE35A
[commit]
	gpgsign = true
[alias]
	lg = log --all --oneline --graph --decorate
	lgc = log --oneline --graph --decorate HEAD @{u}
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	light = true
	syntax-theme = ansi
	; Page with quit-if-one-screen: short diffs auto-quit and stay in the
	; terminal (feels like stdout), long diffs open in less (wrapped +
	; navigable), -X keeps content in scrollback on quit. Paging is also what
	; enables delta's clean line-wrapping of long lines.
	paging = auto
	; less -R keeps delta's ANSI colors; -F quits if the diff fits one screen
	; (so short diffs feel like stdout); -X leaves the content in scrollback
	; on quit. delta's `pager` is a program name, not a never/always switch --
	; that switch is `paging` above.
	pager = less -RFX
	; jj-like minimalism: drop the box/rule "boarding lines" but keep the
	; +/- background highlight (minus-/plus-style left at defaults).
	hunk-header-style = omit
	file-decoration-style = none
	file-style = blue
	; drop the "Δ" modified-file symbol -- show just the path
	file-modified-label = ""
	; line-number gutter without the dotted/solid vertical bars -- just the
	; numbers and a ":" separator, like jj.
	line-numbers-left-format = "{nm:>4} "
	line-numbers-right-format = "{np:>4} : "
	line-numbers-left-style = blue
	line-numbers-right-style = blue
	line-numbers-zero-style = "#cccccc"
[merge]
	conflictStyle = diff3
[diff]
	colorMoved = default
[pager]
	diff = true
[sendemail]
	smtpServer = smtp.gmail.com
	smtpServerPort = 587
	smtpEncryption = tls
	smtpUser = isai.gordeev.2022@polytechnique.org
