# Ghostty config — light theme, JetBrains Mono ExtraLight
# layout/spacing inspired by ~/.dotfiles/hyper/.hyper.js

# --- font ---
font-family = JetBrains Mono
font-style = ExtraLight
font-style-bold = false
font-size = 11.7
adjust-cell-height = 22%
adjust-cell-width = -5%
font-feature = -liga
font-feature = -calt

# --- theme (light/dark) ---
# theme + bg/fg/cursor colors live in theme-dark.conf / theme-light.conf and
# are selected by the theme-active.conf symlink, flipped by toggle_theme.sh
# from the ~/.config/isg/theme source of truth. Put alternate themes there.
config-file = theme-active.conf

cursor-style = block
cursor-style-blink = false
cursor-invert-fg-bg = false
selection-background = f81ce5
selection-foreground = ffffff

# --- window / layout ---
# Hyper had `padding: '8px 15%'` — Ghostty only takes pixels.
# Tune `window-padding-x` to taste; ~240 feels centered on a 13–16" mac.
window-padding-x = 250
window-padding-y = 12
window-padding-balance = true
window-save-state = always
# tabs integrated into the titlebar — most compact tab-friendly option
macos-titlebar-style = hidden
macos-titlebar-proxy-icon = hidden
window-show-tab-bar = never

# --- behavior ---
bold-is-bright = true
copy-on-select = false
mouse-hide-while-typing = true
confirm-close-surface = false
shell-integration = detect
